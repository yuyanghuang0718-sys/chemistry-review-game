    "ionic": {
      "s": { "particle": "ions", "conductivity": false, "properties": ["high_mp", "hard", "brittle"], "reason": "固態離子化合物中，正負離子固定在晶格中，沒有自由移動的帶電粒子，因此不能導電。" },
