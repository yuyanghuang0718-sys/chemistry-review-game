      "aq": { "particle": "ions", "conductivity": true, "properties": ["aqueous_conductive"], "reason": "溶於水後解離成可移動離子，因此水溶液可以導電。" }
    },
    "molecular": {
      "s": { "particle": "molecules", "conductivity": false, "properties": ["low_mp"], "reason": "分子物質由中性分子組成，通常沒有自由移動的帶電粒子，因此不導電。" },
      "l": { "particle": "molecules", "conductivity": false, "properties": ["low_mp"], "reason": "液態分子物質多由中性分子組成，沒有足夠自由離子或電子，因此通常不導電。" },
