{
  "schemaVersion": 1,
  "title": "溶液調配實驗室",
  "sessionLength": 10,
  "source": "高中化學講義第 117–121 頁",
  "equipment": [
    { "id": "balance", "label": "電子天平" },
    { "id": "weighing-paper", "label": "稱量紙" },
    { "id": "beaker", "label": "燒杯" },
    { "id": "glass-rod", "label": "玻璃棒" },
    { "id": "funnel", "label": "漏斗" },
    { "id": "volumetric-flask", "label": "容量瓶" },
    { "id": "wash-bottle", "label": "洗瓶" },
    { "id": "dropper", "label": "滴管" },
    { "id": "volumetric-pipette", "label": "移液管" },
    { "id": "graduated-cylinder", "label": "量筒" },
    { "id": "erlenmeyer-flask", "label": "錐形瓶" },
    { "id": "test-tube", "label": "試管" }
  ],
  "taskTypes": {
    "solid": {
      "label": "固體配製",
      "equipment": ["balance", "weighing-paper", "beaker", "glass-rod", "funnel", "volumetric-flask", "wash-bottle", "dropper"],
      "steps": [
        { "id": "calculate-weigh", "label": "計算所需質量，使用天平稱量溶質" },
        { "id": "partial-dissolve", "label": "放入燒杯，加入少量蒸餾水並攪拌至完全溶解" },
        { "id": "transfer", "label": "經漏斗將溶液定量轉移至容量瓶" },
        { "id": "rinse", "label": "用蒸餾水洗滌燒杯、玻璃棒與漏斗，洗液一併轉入" },
        { "id": "near-mark", "label": "加蒸餾水至接近容量瓶刻度線" },
        { "id": "to-mark", "label": "改用滴管加水，使液面最低點與刻度線相切" },
        { "id": "mix", "label": "塞緊瓶塞，上下倒轉使溶液均勻" }
      ]
    },
    "dilution": {
      "label": "原液稀釋",
      "equipment": ["volumetric-pipette", "volumetric-flask", "wash-bottle", "dropper"],
      "steps": [
        { "id": "rinse-pipette", "label": "以少量原液潤洗移液管" },
        { "id": "measure-stock", "label": "準確量取計算所得的原液體積" },
        { "id": "transfer-stock", "label": "將原液轉移至容量瓶" },
        { "id": "near-mark", "label": "加入蒸餾水至接近刻度線" },
        { "id": "to-mark", "label": "用滴管加水，使液面最低點與刻度線相切" },
        { "id": "mix", "label": "塞緊瓶塞，上下倒轉使溶液均勻" }
      ]
    },
    "volumeDilution": {
      "label": "體積百分濃度調配",
      "equipment": ["graduated-cylinder", "volumetric-flask", "wash-bottle", "dropper"],
      "steps": [
        { "id": "measure-stock", "label": "用量筒量取計算所得的濃酒精體積" },
        { "id": "transfer-stock", "label": "將濃酒精轉移至容量瓶" },
        { "id": "near-mark", "label": "加入蒸餾水至接近刻度線" },
        { "id": "to-mark", "label": "用滴管加水至容量瓶刻度線" },
        { "id": "mix", "label": "塞緊瓶塞，上下倒轉使溶液均勻" }
      ]
    }
  },
